# 宿主机监听地址。保持 0.0.0.0 才能通过局域网 IP 访问。
BIND_ADDRESS=0.0.0.0

# 浏览器访问端口；容器内部固定使用 8099。
HOST_PORT=8099

# Compose 管理的配置持久卷名。Docker 会正确处理非 root 容器的写权限。
DATA_VOLUME=nexus-home-data

# 只有站点位于受信任的 HTTPS 反向代理之后时才设为 1。
TRUST_PROXY=0

# 可选：覆盖 Compose 构建出的本地镜像名。
IMAGE_NAME=nexus-home:local

# Resend 邮件恢复服务。复制为 .env 后填入真实值；不要提交 .env。
RESEND_API_KEY=
RECOVERY_EMAIL_FROM=no-reply@example.com
